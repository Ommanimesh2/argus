# ARGUS Agents — copy to .env and set values

# LLM: choose one (or both; provider selects which to use per call)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Audit (for when you add the full pipeline)
AUDIT_TIMEOUT_SECONDS=300
COMMAND_TIMEOUT_SECONDS=60

# CORS (comma-separated)
ORIGINS=http://localhost:3000,http://localhost:3001

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGCHAIN_API_KEY=

# AWS (for SecureToolExecutor and demo recon/scan)
# Use a profile that assumes the audit-agent role (see AWS_Roles.md). Example ~/.aws/config:
#   [profile argus]
#   role_arn = arn:aws:iam::459281873221:role/audit-agent-role
#   source_profile = default
#   region = us-east-1
AWS_PROFILE=argus
AWS_REGION=us-east-1
# Optional: role ARN from infra (for reference; profile above should assume this role)
# AWS_AGENT_ROLE_ARN=arn:aws:iam::459281873221:role/audit-agent-role

# Phase-3 audit
# AUDIT_MODE: demo = run AWS recon + initial_scan (discovers by tag), then hypothesis→investigation→report. Use this with real AWS infra.
#             dev  = skip recon; load from context_file_path only, then same pipeline. Use when feeding a pre-built context file.
AUDIT_MODE=demo
INVESTIGATION_BUDGET=20
TOKEN_BUDGET=60000

# Models: FAST = discovery, hypothesis, investigation; DEEP = reasoning and report. Same model for both is fine.
# Claude: claude-sonnet-4-20250514 (default). Optional cheaper FAST: claude-3-5-haiku-20241022
# OpenAI: gpt-4o (default). Optional cheaper FAST: gpt-4o-mini
FAST_MODEL=claude-sonnet-4-20250514
DEEP_MODEL=claude-sonnet-4-20250514
