# ARGUS Agents — copy to .env and set values

# LLM: choose one (or both; provider selects which to use per call)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Audit (for when you add the full pipeline)
AUDIT_TIMEOUT_SECONDS=300
COMMAND_TIMEOUT_SECONDS=60

# CORS (comma-separated)
ORIGINS=http://localhost:3000,http://localhost:3001

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGCHAIN_API_KEY=

# Phase-3 audit (demo = recon+scan then loop; dev = load_context then loop)
AUDIT_MODE=demo
INVESTIGATION_BUDGET=20
TOKEN_BUDGET=60000
FAST_MODEL=claude-sonnet-4-20250514
DEEP_MODEL=claude-sonnet-4-20250514
